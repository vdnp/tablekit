{
  "name": "tablekit-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint packages",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "docs:api": "node docs/scripts/generate-api.mjs",
    "docs:check-code": "node docs/scripts/check-code-blocks.mjs",
    "docs:check-links": "node docs/scripts/check-links.mjs",
    "docs:check": "pnpm docs:check-code && pnpm docs:check-links"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turbo": "^2.3.3",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.4.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
