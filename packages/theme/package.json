{
  "name": "@vdnp/tablekit-theme",
  "version": "0.0.0",
  "description": "Design tokens (colors, spacing, typography, radii) for TableKit — consumable from web (CSS variables) and React Native (token objects).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tablekit/tablekit.git",
    "directory": "packages/theme"
  },
  "homepage": "https://github.com/tablekit/tablekit/tree/main/packages/theme#readme",
  "bugs": "https://github.com/tablekit/tablekit/issues",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
