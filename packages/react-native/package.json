{
  "name": "@tablekit/react-native",
  "version": "0.0.0",
  "description": "React Native adapter for TableKit: useDataTable() headless hook + virtualized <DataTable /> built on FlatList (FlashList injectable).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tablekit/tablekit.git",
    "directory": "packages/react-native"
  },
  "homepage": "https://github.com/tablekit/tablekit/tree/main/packages/react-native#readme",
  "bugs": "https://github.com/tablekit/tablekit/issues",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tablekit/core": "workspace:*",
    "@tablekit/theme": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@jest/globals": "^29.7.0",
    "@react-native/babel-preset": "^0.76.5",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "^18.3.18",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-native": "^0.76.5",
    "react-test-renderer": "18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "react-native",
    "datatable",
    "table",
    "flatlist",
    "flashlist"
  ]
}
